{
  "compilerOptions": {
    "target": "ES2020",

    "module": "Node16",
    "moduleResolution": "Node16",

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "strict": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "types": ["node"],

    "ignoreDeprecations": "6.0"
  }
}